library(pairwiseAdonis)
?pairwise.adonis2
for_pair <- pairwise.adonis2(for_com ~ Location, data = foram)
for_pair
for_pair <- pairwise.adonis2(for_com ~ Location*`Sediment Size`, data = foram)
for_pair
for_pair <- pairwise.adonis2(for_com ~ Location, strata = `Sediment Size`, data = foram)
for_pair <- pairwise.adonis2(for_com ~ Location,
data = foram,
strata = 'Sediment Size')
view(iris)
for_pair <- pairwise.adonis2(for_com ~ Location,
data = foram,
strata = `Sediment Size`)
for_pair <- pairwise.adonis2(for_com ~ Location,
data = foram,
strata = "Sediment Size")
dat <- expand.grid(rep=gl(2,1), NO3=factor(c(0,10,30)),field=gl(3,1) )
Agropyron <- with(dat, as.numeric(field) + as.numeric(NO3)+2) +rnorm(18)/2
Schizachyrium <- with(dat, as.numeric(field) - as.numeric(NO3)+2) +rnorm(18)/2
Y <- data.frame(Agropyron, Schizachyrium)
perm <- how(nperm = 199)
setBlocks(perm) <- with(dat, field)
view(dat)
perm <- how(nperm = 999)
setBlocks(perm) <- with(foram,`Sediment Size`)
for_pair <- pairwise.adonis2(for_com ~ Location,
data = foram,
strata = 'Sediment Size')

?select
coral <- coral %>%
mutate(location = as_factor(location),
coral_morphospecies = as_factor(`coral morphospecies`)) %>%  # note inverted comma here
select(!(`coral morphospecies`))
str(coral) # check
m2 <- aov(size_mm ~ location*coral_morphospecies, # interaction of terms here
data = coral)
summary(m2) # summary(your.anova) is needed here to print the full results you need
m2_ph <- TukeyHSD(m2, which = "location")
m2_ph_location
m2_ph_location <- TukeyHSD(m2, which = "location")
m2_ph_location
m2_ph_morph <- TukeyHSD(m2, which = "coral_morphospecies")
m2_ph_int <- TukeyHSD(m2, which = "location:coral_morphospecies")
m2_ph_int
m2_ph_location # print
m2_ph_morph
plot(m2_ph_location)
plot(m2_ph_location)
m2_ph_morph <- TukeyHSD(m2, which = "coral_morphospecies")
m2_ph_morph
